# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
.Python
build/
dist/
*.egg-info/
*.egg

# Virtual envs
.venv/
venv/
env/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# NWT runtime data — never commit a project's own timeline
.nwt/

# Secrets — never commit credentials, tokens, or keys of any kind
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets.*
credentials.*
*id_rsa*
*id_ed25519*
# GitHub / GitLab / generic API tokens (defence in depth — never the source of truth)
*ghp_*
*gho_*
*ghu_*
*ghs_*
*ghr_*
*github_pat_*
*glpat-*
